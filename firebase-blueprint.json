{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "An event that contains photos",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the event" },
        "date": { "type": "number", "description": "Timestamp of the event day" },
        "location": { "type": "string", "description": "Location of the event" },
        "clientName": { "type": "string", "description": "Client name" },
        "slug": { "type": "string", "description": "Friendly URL slug" },
        "dpi": { "type": "number", "description": "Image quality: 150, 300, or 600" },
        "logoUrl": { "type": "string", "description": "Base64 logo of the event" },
        "overlays": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "orientation": { "type": "string" }
            }
          }
        },
        "shareText": { "type": "string", "description": "WhatsApp share text" },
        "smsShareText": { "type": "string", "description": "SMS share text" },
        "isPublic": { "type": "boolean", "description": "Open to public or restricted" },
        "identifyParticipants": { "type": "boolean", "description": "Require LGPD form for viewers" },
        "enableMobileCapture": { "type": "boolean", "description": "Enable mobile photo capture" },
        "ownerId": { "type": "string", "description": "The user ID of the event owner" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["name", "date", "location", "clientName", "slug", "dpi", "logoUrl", "overlays", "shareText", "smsShareText", "isPublic", "identifyParticipants", "ownerId", "createdAt"]
    },
    "Photo": {
      "title": "Photo",
      "description": "A photo uploaded to an event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string", "description": "The ID of the event this photo belongs to" },
        "uploaderId": { "type": "string", "description": "The user ID of the person who uploaded" },
        "dataUrl": { "type": "string", "description": "Base64 encoded image data" },
        "createdAt": { "type": "number", "description": "Timestamp of upload" }
      },
      "required": ["eventId", "uploaderId", "dataUrl", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User account created by superadmin",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with superadmin privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    },
    "Participant": {
      "title": "Participant",
      "description": "User who agreed to LGPD to download photos",
      "type": "object",
      "properties": {
        "eventId": { "type": "string", "description": "The ID of the event" },
        "userId": { "type": "string", "description": "The user ID of the downloader" },
        "name": { "type": "string", "description": "Name of the participant" },
        "phone": { "type": "string", "description": "Phone of the participant" },
        "lgpdAgreed": { "type": "boolean", "description": "Checks if LGPD was agreed" },
        "createdAt": { "type": "number", "description": "Timestamp of registration" }
      },
      "required": ["eventId", "userId", "name", "phone", "lgpdAgreed", "createdAt"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global user settings (like integrations)",
      "type": "object",
      "properties": {
        "mobizon": { 
          "type": "object",
          "properties": {
             "apiKey": { "type": "string" },
             "senderName": { "type": "string" }
          }
        },
        "updatedAt": { "type": "number" }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "Captured lead from photo sharing",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "method": { "type": "string" },
        "dataSharingConsent": { "type": "boolean", "description": "Consent to use data for photo sharing" },
        "commercialConsent": { "type": "boolean", "description": "Consent to receive commercial contacts" },
        "createdAt": { "type": "number" }
      },
      "required": ["eventId", "createdAt", "dataSharingConsent"]
    },
    "MessageLog": {
      "title": "MessageLog",
      "description": "Log of messages sent via SMS or WhatsApp",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "photoId": { "type": "string" },
        "recipientName": { "type": "string" },
        "recipientPhone": { "type": "string" },
        "method": { "type": "string", "enum": ["whatsapp", "sms"] },
        "status": { "type": "string" },
        "messageText": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["eventId", "method", "messageText", "createdAt"]
    },
    "ShortLink": {
      "title": "ShortLink",
      "description": "Mapping from short code to full photo URL",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["photo", "capture", "gallery"] },
        "eventId": { "type": "string" },
        "photoId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["eventId", "createdAt"]
    }
  },
  "firestore": {
    "/shortLinks/{shortCode}": {
      "schema": { "$ref": "#/entities/ShortLink" },
      "description": "Stores short link redirects"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores created users"
    },
    "/settings/{userId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Stores global settings per user"
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Stores admin users"
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Stores all events"
    },
    "/events/{eventId}/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Stores captured leads from SMS/WhatsApp sharing"
    },
    "/events/{eventId}/photos/{photoId}": {
      "schema": { "$ref": "#/entities/Photo" },
      "description": "Stores photos for a specific event"
    },
    "/events/{eventId}/participants/{participantId}": {
      "schema": { "$ref": "#/entities/Participant" },
      "description": "Stores participants who downloaded photos"
    },
    "/events/{eventId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/MessageLog" },
      "description": "Stores logs of messages sent via SMS or WhatsApp"
    }
  }
}
